{
  "entities": {
    "Bird": {
      "title": "Bird",
      "description": "A bird in the breeding facility.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name or ID of the bird." },
        "species": { "type": "string", "description": "The species of the bird." },
        "subSpecies": { "type": "string", "description": "The sub-species of the bird." },
        "sex": { "type": "string", "enum": ["Male", "Female", "Unknown"] },
        "birthDate": { "type": "string", "format": "date", "description": "The birth date of the bird." },
        "cageId": { "type": "string", "description": "The ID of the cage the bird is in." },
        "motherId": { "type": "string", "description": "The ID of the mother bird." },
        "fatherId": { "type": "string", "description": "The ID of the father bird." },
        "mateId": { "type": "string", "description": "The ID of the bird's mate." },
        "offspringIds": { "type": "array", "items": { "type": "string" }, "description": "IDs of the bird's offspring." },
        "mutations": { "type": "array", "items": { "type": "string" }, "description": "List of mutations." },
        "splitMutations": { "type": "array", "items": { "type": "string" }, "description": "List of split mutations." },
        "statuses": { "type": "array", "items": { "type": "string" }, "description": "List of custom statuses." },
        "imageUrl": { "type": "string", "description": "Data URL or external URL of the bird's image." },
        "notes": { "type": "string", "description": "General notes about the bird." },
        "purchaseDate": { "type": "string", "format": "date" },
        "purchasePrice": { "type": "number" },
        "estimatedValue": { "type": "number" },
        "uid": { "type": "string", "description": "The owner's user ID." }
      },
      "required": ["name", "species", "sex", "uid"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction related to the facility or a bird.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["Income", "Expense"] },
        "category": { "type": "string", "description": "Category of the transaction (e.g., Feed, Sale, Purchase)." },
        "amount": { "type": "number", "description": "The amount in currency." },
        "date": { "type": "string", "format": "date", "description": "When the transaction occurred." },
        "birdId": { "type": "string", "description": "Optional ID of a bird linked to this transaction." },
        "description": { "type": "string", "description": "Optional details." },
        "uid": { "type": "string", "description": "The owner's user ID." }
      },
      "required": ["type", "category", "amount", "date", "uid"]
    },
    "Cage": {
      "title": "Cage",
      "description": "A cage or aviary.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name or number of the cage." },
        "location": { "type": "string", "description": "The location of the cage." },
        "uid": { "type": "string", "description": "The owner's user ID." }
      },
      "required": ["name", "uid"]
    },
    "Pair": {
      "title": "Pair",
      "description": "A breeding pair of birds.",
      "type": "object",
      "properties": {
        "maleId": { "type": "string", "description": "The ID of the male bird." },
        "femaleId": { "type": "string", "description": "The ID of the female bird." },
        "startDate": { "type": "string", "format": "date", "description": "When the pair was formed." },
        "endDate": { "type": "string", "format": "date", "description": "When the pair was separated." },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "uid": { "type": "string", "description": "The owner's user ID." }
      },
      "required": ["maleId", "femaleId", "status", "uid"]
    },
    "Task": {
      "title": "Task",
      "description": "A task or note related to bird care.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the task." },
        "description": { "type": "string", "description": "Detailed description." },
        "status": { "type": "string", "enum": ["Pending", "Completed"] },
        "dueDate": { "type": "string", "format": "date" },
        "birdIds": { "type": "array", "items": { "type": "string" }, "description": "Tagged birds." },
        "subTasks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "completed": { "type": "boolean" },
              "birdIds": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "uid": { "type": "string", "description": "The owner's user ID." }
      },
      "required": ["title", "status", "uid"]
    },
    "BreedingRecord": {
      "title": "Breeding Record",
      "description": "A record of breeding activity for a pair.",
      "type": "object",
      "properties": {
        "pairId": { "type": "string", "description": "The ID of the breeding pair." },
        "startDate": { "type": "string", "format": "date", "description": "When the breeding started." },
        "endDate": { "type": "string", "format": "date", "description": "When the breeding ended." },
        "eggsLaid": { "type": "number", "description": "Number of eggs laid." },
        "eggsHatched": { "type": "number", "description": "Number of eggs hatched." },
        "chicksWeaned": { "type": "number", "description": "Number of chicks weaned." },
        "offspringIds": { "type": "array", "items": { "type": "string" }, "description": "IDs of offspring from this record." },
        "notes": { "type": "string", "description": "Optional notes." },
        "uid": { "type": "string", "description": "The owner's user ID." }
      },
      "required": ["pairId", "startDate", "eggsLaid", "eggsHatched", "chicksWeaned", "uid"]
    },
    "UserSettings": {
      "title": "User Settings",
      "description": "User's configuration and custom data.",
      "type": "object",
      "properties": {
        "species": { "type": "array", "items": { "object": {} } },
        "subspecies": { "type": "array", "items": { "object": {} } },
        "mutations": { "type": "array", "items": { "object": {} } },
        "uid": { "type": "string" },
        "currency": { "type": "string" },
        "account_expiry_date": { "type": "string", "format": "date-time" }
      },
      "required": ["species", "subspecies", "mutations", "uid"]
    },
    "PushSubscription": {
      "title": "Push Subscription",
      "description": "A push notification subscription for a user.",
      "type": "object",
      "properties": {
        "endpoint": { "type": "string" },
        "keys": {
          "type": "object",
          "properties": {
            "auth": { "type": "string" },
            "p256dh": { "type": "string" }
          }
        },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["endpoint", "keys", "userId"]
    },
    "SharedItem": {
      "title": "Shared Item",
      "description": "A shared item (bird, pair, cage).",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["bird", "pair", "cage"] },
        "action": { "type": "string", "enum": ["share"] },
        "data": { "type": "string", "description": "JSON stringified data of the item." },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["type", "action", "data", "createdAt", "createdBy"]
    }
  },
  "firestore": {
    "/birds/{birdId}": { "schema": "Bird", "description": "Collection of birds." },
    "/cages/{cageId}": { "schema": "Cage", "description": "Collection of cages." },
    "/pairs/{pairId}": { "schema": "Pair", "description": "Collection of breeding pairs." },
    "/breedingRecords/{recordId}": { "schema": "BreedingRecord", "description": "Collection of breeding records." },
    "/tasks/{taskId}": { "schema": "Task", "description": "Collection of tasks and notes." },
    "/transactions/{transactionId}": { "schema": "Transaction", "description": "Collection of financial transactions." },
    "/userSettings/{userId}": { "schema": "UserSettings", "description": "User's settings and custom data." },
    "/push_subscriptions/{subId}": { "schema": "PushSubscription", "description": "Collection of push notification subscriptions." },
    "/shared_items/{itemId}": { "schema": "SharedItem", "description": "Collection of shared items." }
  }
}
